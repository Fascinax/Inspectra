# ─── Stripe Minions: Hard Blocks ────────────────────────────────────────────
# Prevent agents from modifying governance files without human approval
PROTECTED_DIRS=".github/agents schemas policies"
for dir in $PROTECTED_DIRS; do
  if git diff --cached --name-only | grep -q "^$dir/"; then
    echo "⛔ HARD BLOCK: Changes to $dir/ require explicit human approval."
    echo "   If this is intentional, commit with: git commit --no-verify"
    exit 1
  fi
done

# ─── Stripe Minions: Per-Agent Isolation Guard ──────────────────────────────
# Detect commits that touch files from multiple agent domains
# This prevents cross-domain contamination from agent-assisted work
STAGED_FILES=$(git diff --cached --name-only)
DOMAIN_COUNT=0

echo "$STAGED_FILES" | grep -q "mcp/src/tools/security\|mcp/src/register/security"    && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/tests\|mcp/src/register/tests"           && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/architecture\|mcp/src/register/arch"     && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/conventions\|mcp/src/register/conv"      && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/performance\|mcp/src/register/perf"      && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/documentation\|mcp/src/register/doc"     && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))
echo "$STAGED_FILES" | grep -q "mcp/src/tools/tech-debt\|mcp/src/register/tech-debt"   && DOMAIN_COUNT=$((DOMAIN_COUNT + 1))

if [ "$DOMAIN_COUNT" -gt 1 ]; then
  echo "⚠️  ISOLATION WARNING: This commit touches $DOMAIN_COUNT domain tool files."
  echo "   Stripe Minions principle: one agent, one domain, one commit."
  echo "   If this is a cross-cutting refactor, commit with: git commit --no-verify"
  exit 1
fi

# ─── Stripe Minions: Quality Gates ──────────────────────────────────────────
# 1. TypeScript type checking (strictest possible)
echo "🔍 Type checking..."
npx tsc --noEmit --project mcp/tsconfig.src.json || exit 1

# 2. ESLint (strictest possible linting)
echo "🔍 Linting..."
npx lint-staged || exit 1

# 3. Tests + Coverage (100% pass rate + 80% coverage thresholds)
echo "🧪 Running tests with coverage..."
npx vitest run --coverage || exit 1
