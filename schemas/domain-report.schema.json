{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://inspectra.dev/schemas/domain-report.schema.json",
  "title": "Inspectra Domain Report",
  "description": "Report produced by a single domain agent (security, tests, architecture, conventions).",
  "type": "object",
  "required": ["domain", "score", "summary", "findings", "metadata"],
  "properties": {
    "domain": {
      "type": "string",
      "enum": ["security", "tests", "architecture", "conventions", "performance", "documentation"],
      "description": "Audit domain."
    },
    "score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Domain score (0 = critical failures, 100 = exemplary)."
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "One-line human-readable summary (e.g., '2 high, 3 medium, 5 low')."
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "finding.schema.json" },
      "description": "All findings for this domain."
    },
    "metadata": {
      "type": "object",
      "required": ["agent", "timestamp"],
      "properties": {
        "agent": {
          "type": "string",
          "description": "Name of the agent that produced this report."
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of report generation."
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Execution time in milliseconds."
        },
        "tools_used": {
          "type": "array",
          "items": { "type": "string" },
          "description": "MCP tools invoked during this audit."
        }
      }
    }
  },
  "additionalProperties": false
}
