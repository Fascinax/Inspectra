  "root_causes": [
    {
      "id": "RC-001",
      "title": "No accessibility testing or checklist",
      "description": "Images missing alt text, interactive elements missing aria-labels, inputs missing labels, HTML missing lang — all basic WCAG 2.1 violations",
      "symptoms": ["ACC-GT-001", "ACC-GT-002", "ACC-GT-003", "ACC-GT-004", "ACC-GT-005", "ACC-GT-006", "ACC-GT-007"],
      "fix": "Add axe-core or pa11y to CI, create component a11y checklist"
    },
    {
      "id": "RC-002",
      "title": "No i18n pipeline despite ngx-translate dependency",
      "description": "ngx-translate is installed but all user-facing strings are hardcoded in templates instead of using translate pipe",
      "symptoms": ["I18N-GT-001", "I18N-GT-002", "I18N-GT-003", "I18N-GT-004"],
      "fix": "Extract all user-facing strings to translation JSON files, use {{ 'KEY' | translate }} pipe"
    },
    {
      "id": "RC-003",
      "title": "No design token system",
      "description": "Colors are hardcoded as hex values in inline styles and SCSS instead of using CSS custom properties. Only 1 CSS variable exists (--primary) but is inconsistently used.",
      "symptoms": ["UX-GT-001", "UX-GT-002", "UX-GT-003", "UX-GT-004"],
      "fix": "Define design tokens as CSS custom properties, replace all hardcoded hex colors, ban inline styles"
    }
  ],
