  ],
  "root_causes": [
    {
      "id": "RC-001",
      "title": "Spring Security misconfiguration",
      "description": "Security is effectively disabled: CSRF off, all requests permitted, CORS accepts any origin with credentials, actuator endpoints fully exposed, error details leaked",
      "symptoms": ["SEC-GT-002", "SEC-GT-003", "SEC-GT-004", "SEC-GT-005", "SEC-GT-006", "SEC-GT-008"],
      "fix": "Configure role-based access, restrict CORS to known origins, limit actuator exposure, disable stacktrace in production"
    },
    {
      "id": "RC-002",
      "title": "JPA/Hibernate anti-patterns on entity design",
      "description": "@Data on entities breaks equals/hashCode, CascadeType.ALL on @ManyToOne causes unintended deletes, missing @Version prevents optimistic locking, missing @Modifying on UPDATE queries",
      "symptoms": ["DEBT-GT-001", "DEBT-GT-002", "DEBT-GT-003", "DEBT-GT-004"],
      "fix": "Use @Getter/@Setter instead of @Data, scope cascade to PERSIST/MERGE, add @Version field, add @Modifying on UPDATE queries"
    },
    {
      "id": "RC-003",
      "title": "No API design standards",
      "description": "REST controller uses HttpSession (stateful), returns unbounded List without pagination, no input validation on @RequestBody",
      "symptoms": ["API-GT-001", "API-GT-002", "SEC-GT-007"],
      "fix": "Remove HttpSession usage, add Pageable to list endpoints, add @Valid on all @RequestBody params"
    }
  ],
