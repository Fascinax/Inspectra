{
  "repo": "bench-ts-express",
  "stack": "typescript-node",
  "description": "Express REST API with auth, users, products — seeded with security, API design, observability, testing, conventions, and tech-debt issues",
  "expert_ranking": [
    "SEC-GT-001",
    "SEC-GT-002",
    "SEC-GT-003",
    "OBS-GT-001",
    "TST-GT-001",
    "API-GT-001",
    "DEBT-GT-002",
    "OBS-GT-002"
  ],
  "root_causes": [
    {
      "id": "RC-001",
      "title": "No secret management strategy",
      "description": "All secrets are hardcoded in source files instead of using environment variables or a vault",
      "symptoms": ["SEC-GT-001", "SEC-GT-002", "SEC-GT-003"],
      "fix": "Move all secrets to environment variables or a secret manager (Vault, AWS Secrets Manager)"
    },
    {
      "id": "RC-002",
      "title": "No REST API design guidelines",
      "description": "Routes use verb-based paths (/getUser, /createUser) instead of resource-based REST conventions (/users, /users/:id)",
      "symptoms": ["API-GT-001", "API-GT-002", "API-GT-003", "API-GT-004"],
      "fix": "Adopt resource-based REST conventions with proper HTTP verbs"
    },
    {
      "id": "RC-003",
      "title": "No test mandate or CI gate",
      "description": "Only 1 of 3 services has a test file; no coverage threshold enforced",
      "symptoms": ["TST-GT-001", "TST-GT-002"],
      "fix": "Add test coverage gate to CI pipeline, require tests for new services"
    },
    {
      "id": "RC-004",
      "title": "No observability strategy",
      "description": "No health endpoint, exceptions are swallowed silently in catch blocks, no structured logging",
      "symptoms": ["OBS-GT-001", "OBS-GT-002", "OBS-GT-003", "OBS-GT-004"],
      "fix": "Add health endpoint, define error-handling policy (never swallow, always log), adopt structured logger"
    }
  ],
