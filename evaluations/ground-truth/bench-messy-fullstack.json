  "root_causes": [
    {
      "id": "RC-001",
      "title": "No secret management",
      "description": "Multiple hardcoded secrets scattered across files: DB passwords, JWT secret, SMTP password, connection strings",
      "symptoms": ["SEC-GT-001", "SEC-GT-002", "SEC-GT-003", "SEC-GT-004"],
      "fix": "Move all secrets to environment variables, add .env.example, add secret scanning to CI"
    },
    {
      "id": "RC-002",
      "title": "God object anti-pattern (app.ts)",
      "description": "Single file handles server setup, auth, CRUD for 3 entities, email, caching, reporting — 220+ lines with no separation of concerns",
      "symptoms": ["DEBT-GT-001", "DEBT-GT-002", "DEBT-GT-003", "CNV-GT-004", "OBS-GT-002"],
      "fix": "Decompose into modules: routes, controllers, services, middleware. Apply single responsibility principle."
    },
    {
      "id": "RC-003",
      "title": "No code quality standards",
      "description": "Mixed naming conventions (PascalCase, camelCase, snake_case, SCREAMING_CASE for functions), duplicated utility functions across 3 files, no linter, no formatter",
      "symptoms": ["CNV-GT-001", "CNV-GT-002", "CNV-GT-003", "DEBT-GT-004", "DEBT-GT-005"],
      "fix": "Adopt consistent naming convention, centralize utilities, enable ESLint + Prettier"
    },
    {
      "id": "RC-004",
      "title": "No REST API design",
      "description": "All routes use verb-based paths (/getUsers, /createUser, /deleteUser), no versioning, no resource-based structure",
      "symptoms": ["API-GT-001", "API-GT-002", "API-GT-003", "API-GT-004", "API-GT-005"],
      "fix": "Adopt resource-based REST conventions with proper HTTP verbs"
    },
    {
      "id": "RC-005",
      "title": "Zero test coverage",
      "description": "No test files exist anywhere in the project — no unit tests, no integration tests",
      "symptoms": ["TST-GT-001"],
      "fix": "Add test framework (Vitest/Jest), write critical path tests, add coverage gate to CI"
    }
  ],
