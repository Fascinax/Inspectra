{
  "name": "inspectra",
  "version": "0.7.3",
  "description": "Hybrid code audit system powered by GitHub Copilot and MCP",
  "type": "module",
  "packageManager": "npm@10",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fascinax/Inspectra.git"
  },
  "homepage": "https://github.com/Fascinax/Inspectra#readme",
  "bugs": {
    "url": "https://github.com/Fascinax/Inspectra/issues"
  },
  "keywords": [
    "audit",
    "mcp",
    "copilot",
    "agents",
    "code-quality",
    "static-analysis",
    "developer-tools"
  ],
    "bin": "./bin/init.mjs",
  "files": [
    "bin/",
    "mcp/dist/",
    "mcp/package.json",
    ".github/prompts/",
    "policies/",
    "schemas/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:mcp",
    "build:mcp": "npm run build --workspace=mcp",
    "dev": "npm run dev --workspace=mcp",
    "lint": "tsc --noEmit --project mcp/tsconfig.src.json && eslint mcp/src/",
    "lint:fix": "eslint mcp/src/ --fix",
    "format": "prettier --write mcp/src/",
    "format:check": "prettier --check mcp/src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate:schemas": "bash scripts/validate-schemas.sh",
    "test:inspector": "node scripts/test-mcp-inspector.mjs",
    "clean": "rimraf mcp/dist",
    "init": "node bin/init.mjs",
    "release:check": "npm publish --dry-run"
  },
  "workspaces": [
    "mcp"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@typescript-eslint/typescript-estree": "^8.56.1",
    "fast-xml-parser": "^5.4.2",
    "globby": "^14.0.0",
    "handlebars": "^4.7.8",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "puppeteer": "^24.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
