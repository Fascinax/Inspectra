{
  "name": "inspectra",
  "version": "0.1.0",
  "description": "Multi-agent code audit system powered by GitHub Copilot Custom Agents and MCP",
  "private": true,
  "type": "module",
  "bin": {
    "inspectra": "./bin/init.mjs",
    "inspectra-audit": "./mcp/dist/cli/audit.js"
  },
  "scripts": {
    "build": "npm run build --workspace=mcp",
    "dev": "npm run dev --workspace=mcp",
    "lint": "tsc --noEmit --project mcp/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit-local": "node mcp/dist/cli/audit.js",
    "validate:schemas": "bash scripts/validate-schemas.sh",
    "clean": "rimraf mcp/dist",
    "init": "node bin/init.mjs"
  },
  "workspaces": [
    "mcp"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
