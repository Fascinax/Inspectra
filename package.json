{
  "name": "inspectra",
  "version": "0.3.0",
  "description": "Multi-agent code audit system powered by GitHub Copilot Custom Agents and MCP",
  "private": true,
  "type": "module",
  "bin": {
    "inspectra": "./bin/init.mjs",
    "inspectra-audit": "./mcp/dist/cli/audit.js"
  },
  "scripts": {
    "build": "npm run build --workspace=mcp",
    "dev": "npm run dev --workspace=mcp",
    "lint": "tsc --noEmit --project mcp/tsconfig.src.json && eslint mcp/src/",
    "lint:fix": "eslint mcp/src/ --fix",
    "format": "prettier --write mcp/src/",
    "format:check": "prettier --check mcp/src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "audit-local": "node mcp/dist/cli/audit.js",
    "validate:schemas": "bash scripts/validate-schemas.sh",
    "clean": "rimraf mcp/dist",
    "init": "node bin/init.mjs"
  },
  "workspaces": [
    "mcp"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}

